<%= render partial: 'projects/edit_project_nav' %>

<h2>Publish Targets Enabled For This Project</h2>

<%= form_for(@project, url: project_publish_targets_path(@project), method: 'patch') do |f| %>

  <% if @project.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:</h2>

      <ul>
      <% @project.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.collection_select(:publish_target_ids, PublishTarget.all.order(:display_label), :id, :display_label,
      {},
      { multiple: true, class: 'chosen-select', 'data-placeholder': 'Type or click to select a publish target...' })
  %>

  <br /><br />
  <div class="actions">
    <%= f.submit('Save', class: 'btn btn-primary') %>
  </div>

<% end %>
